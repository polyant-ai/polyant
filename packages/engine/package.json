{
  "name": "@polyant/engine",
  "version": "0.1.0",
  "description": "Polyant AI runtime engine and management API",
  "license": "AGPL-3.0-or-later",
  "author": "Exelab S.r.l.",
  "homepage": "https://github.com/polyant-ai/polyant",
  "repository": {
    "type": "git",
    "url": "https://github.com/polyant-ai/polyant.git",
    "directory": "packages/engine"
  },
  "bugs": {
    "url": "https://github.com/polyant-ai/polyant/issues"
  },
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "db:generate": "tsx ../../node_modules/drizzle-kit/bin.cjs generate",
    "db:migrate": "tsx src/database/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "lint": "eslint src/",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:unit": "vitest run --exclude '**/*.integration.test.ts' --exclude '**/*.functional.test.ts'",
    "test:integration": "vitest run --fileParallelism=false 'integration'",
    "test:functional": "vitest run --fileParallelism=false 'functional'"
  },
  "dependencies": {
    "@ai-sdk/amazon-bedrock": "^2.2.12",
    "@ai-sdk/anthropic": "^1.0.0",
    "@ai-sdk/openai": "^1.0.0",
    "@aws-sdk/client-s3": "^3.1052.0",
    "@aws-sdk/client-transcribe-streaming": "^3.1052.0",
    "@aws-sdk/credential-providers": "^3.1065.0",
    "@nestjs/common": "^11.1.13",
    "@nestjs/core": "^11.1.13",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/throttler": "^6.5.0",
    "@panva/hkdf": "^1.2.1",
    "@slack/bolt": "^4.6.0",
    "@tavily/core": "^0.0.3",
    "ai": "^4.0.0",
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "croner": "^10.0.1",
    "dotenv": "^16.4.0",
    "drizzle-orm": "^0.45.2",
    "grammy": "^1.40.0",
    "helmet": "^8.1.0",
    "jose": "^6.2.2",
    "langsmith": "^0.7.2",
    "postgres": "^3.4.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2",
    "shell-quote": "^1.8.3",
    "twilio": "^5.13.1",
    "undici": "^8.4.1",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/node": "^22.0.0",
    "@types/shell-quote": "^1.7.5",
    "@vitest/coverage-v8": "^4.1.4",
    "drizzle-kit": "^0.31.10",
    "eslint": "^9.0.0",
    "fast-check": "^4.6.0",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0",
    "typescript-eslint": "^8.0.0",
    "vitest": "^4.1.4"
  }
}
