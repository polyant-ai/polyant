# =============================================================================
# Polyant — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in the required values.
# AI provider keys, LangSmith, auth, and channel credentials are configured
# per-instance via the admin panel (Settings tab) — not here.
#
# Required for engine: DATABASE_URL, ENCRYPTION_KEY, AUTH_SECRET, AUTH_INTERNAL_SECRET
# Required for web:    AUTH_SECRET, AUTH_INTERNAL_SECRET (mirror the engine values into packages/web/.env.local)
# Optional for web:    GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET (enables Google sign-in; if unset the credentials flow remains, and the Google button is hidden)
# =============================================================================

# --- Database (PostgreSQL 16 + pgvector) ---
# Full connection string used by the engine (Drizzle ORM).
DATABASE_URL=postgresql://polyant:changeme@localhost:5432/polyant

# Docker Compose creates the DB using these individual vars.
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=polyant
POSTGRES_USER=polyant
POSTGRES_PASSWORD=changeme

# --- HTTP Server (NestJS engine) ---
API_PORT=4000

# --- Encryption ---
# 32-byte hex key for AES-256-GCM encryption of instance secrets and skill env vars.
# Generate with: openssl rand -hex 32
ENCRYPTION_KEY=

# --- Authentication ---
# Shared secret between engine and web for JWT verification (Auth.js JWE).
# Must be identical in both packages. Generate with: openssl rand -hex 32
AUTH_SECRET=

# Set to true when running behind a reverse proxy (Render, Railway, etc.)
AUTH_TRUST_HOST=

# --- Google OAuth (web only) ---
# Create credentials at https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional: restrict sign-in to specific email domains (comma-separated).
# Leave empty to allow any Google account. For production deployments you
# almost certainly want to restrict this — see docs/deployment.md.
# Example: AUTH_ALLOWED_DOMAINS=mycompany.com,partner.com
AUTH_ALLOWED_DOMAINS=

# Comma-separated list of origins allowed to call the engine API (CORS).
# Leave empty in development if engine and web run on the same origin (rewrites).
# In production, set this to the public origin of your web app.
# Example: CORS_ORIGINS=https://app.example.com,https://admin.example.com
# A credentialed wildcard (`*`) is refused at startup — list explicit origins.
CORS_ORIGINS=

# --- Reverse proxy ---
# Number of trusted proxy hops between the engine and the public internet
# (e.g. set to `1` if a single reverse proxy like Render/Railway/nginx sits in
# front of the engine). Controls whether `X-Forwarded-Host` / `X-Forwarded-Proto`
# headers are honored when reconstructing the request URL for the Twilio
# webhook signature check. Accepts an integer hop count or `true`/`false`.
# Leave at `0` (default) if the engine is exposed directly — otherwise
# attackers could spoof Host/Proto and bypass the Twilio HMAC.
TRUST_PROXY=0

# --- Instance ---
# Default instance slug for single-instance deployments.
DEFAULT_INSTANCE_ID=default

# --- Web → Engine URL ---
# URL the Next.js frontend uses to reach the engine API (server-side rewrites).
NEXT_PUBLIC_API_URL=http://localhost:4000

# Internal URL the web's Credentials provider uses to call the engine's
# /api/auth/credentials/verify endpoint (server-side only). Defaults to
# http://localhost:4000. In production, point this at the engine's internal
# address (e.g. http://engine:4000 inside a private network).
INTERNAL_ENGINE_URL=http://localhost:4000

# --- Platform S3 (optional — for persisting conversation attachments) ---
# When configured, file attachments from WhatsApp/Telegram are stored in S3
# and served via the /api/attachments proxy endpoint.
# If not configured, attachments are not persisted across restarts.
PLATFORM_S3_BUCKET=
PLATFORM_S3_REGION=
PLATFORM_S3_ACCESS_KEY_ID=
PLATFORM_S3_SECRET_ACCESS_KEY=

# --- Message coordinator (WhatsApp/Telegram inbound) ---
# Collapses burst fragments into one pipeline run and cancels/restarts the
# in-flight pipeline when new fragments arrive — keeps UX responsive.

# Pre-pipeline coalescing window (ms). Burst fragments within this window
# are concatenated into one call. Default 2000.
MESSAGE_SOFT_DEBOUNCE_MS=2000

# Delay before sending the channel's typing indicator (ms). Starts the
# "typing…" UX a little after the first fragment — humanises the flow.
# Default 1500.
MESSAGE_TYPING_DELAY_MS=1500

# Cap on consecutive cancel-and-restart cycles per conversation. Once
# reached, further fragments accumulate and are flushed after the current
# pipeline completes. Default 3.
MESSAGE_MAX_RESTARTS=3

# --- Agent-to-agent (virtual `agent` channel) ---
# Max wall-clock duration (ms) of a single sub-agent invocation via the
# virtual in-process `agent` channel. On timeout the synthesised tool
# returns an error string to the caller. Default 60000 (60s).
AGENT_CALL_TIMEOUT_MS=60000

# --- Activity stream (SSE) resource limits ---
# Caps on concurrent subscribers of GET /api/activity-stream/live. Excess
# connections are rejected with HTTP 503 + Retry-After: 60.
#   - SSE_MAX_CONNECTIONS:          global cap across all users. Default 50.
#   - SSE_MAX_CONNECTIONS_PER_USER: per-authenticated-user cap. Default 5.
SSE_MAX_CONNECTIONS=50
SSE_MAX_CONNECTIONS_PER_USER=5

# --- Knowledge resource limits ---
# Hard cap on the number of knowledge documents an instance may hold.
# Uploads beyond the cap are rejected with HTTP 400; workspace sync
# reports the refused files in the response (refusedCap[]).
# Default 500.
KNOWLEDGE_MAX_DOCS_PER_INSTANCE=500

# --- Workspace storage ---
# Filesystem root for per-conversation sandbox directories used by the
# readFile / writeFile / gitCloneRepo tools
# (<root>/<instance>/conversations/<conv>/). Knowledge documents live
# in PostgreSQL, not here. Defaults to packages/engine/workspaces
# resolved to an absolute path. One of the two documented process.env
# reads outside config.ts (the other is DEFAULT_INSTANCE_ID).
# WORKSPACES_ROOT=

# --- Similarity threshold (memory deduplication) ---
# Cosine similarity threshold above which a new memory is considered a duplicate.
# Range: 0.0–1.0. Default: 0.90
DEDUP_SIMILARITY_THRESHOLD=0.90

# --- Analytics retention ---
# Daily housekeeping deletes rows older than this many days from `ai_logs`
# and `pipeline_traces`. Both tables grow at one row per LLM call / pipeline
# run, so unbounded retention is not recommended. Default: 90.
ANALYTICS_RETENTION_DAYS=90

# --- Base URL ---
# Public base URL of the engine (used for webhook callback URLs, etc.)
BASE_URL=http://localhost:4000

# --- Locale ---
# Default timezone and locale used by the supervisor system prompt to format
# dates/times. Per-instance overrides happen at the prompt level.
DATETIME_TIMEZONE=UTC
DATETIME_LOCALE=en-US

# --- GitHub integration ---
# GitHub Personal Access Token used by gitCloneRepo is stored per-instance in
# instance_secrets.github_token (encrypted). Configure via the admin panel
# Settings tab. No env var required.

# --- Tracing (optional, opt-in) ---
# LangSmith credentials are configured per-instance via the admin panel
# (Settings tab) — not here. Leave the keys below unset unless you want a
# global fallback for development. See docs for details.
# LANGSMITH_API_KEY=
# LANGSMITH_PROJECT=
# LANGSMITH_TRACING=false

# --- Debug (DEVELOPMENT ONLY) ---
# When set to 1, the engine logs the full LLM request payload (system prompt,
# message contents, tool names) to stdout. The system prompt may contain
# instance secrets, customer PII pulled from memory, and other sensitive data.
# WARNING: Never enable this in production. Leave unset (or =0) by default.
# DEBUG_LLM_PAYLOAD=0

# ─── Auth ────────────────────────────────────────────────────────────
# Shared secret used by the web's Credentials provider to call the engine's
# /api/auth/credentials/verify endpoint. Must be identical in engine and web
# .env files. When unset, email/password login is disabled (Google-only).
# Generate with: openssl rand -hex 32
AUTH_INTERNAL_SECRET=

# Initial admin user — created on first boot if the users table is empty.
# INITIAL_ADMIN_PASSWORD is REQUIRED to seed the admin: if unset, seeding is
# skipped (no auto-generation) to avoid writing the secret to the engine logs.
# INITIAL_ADMIN_EMAIL is optional (defaults to administrator@local).
INITIAL_ADMIN_EMAIL=
INITIAL_ADMIN_PASSWORD=
